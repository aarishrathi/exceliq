# Anthropic (optional — enables AI summaries on version 2+)
ANTHROPIC_API_KEY=

# Vercel Blob (optional — used when POSTGRES_URL is also set)
BLOB_READ_WRITE_TOKEN=

# Vercel Postgres (optional — omit for local .data/ file store)
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=

# App (next-auth reserved for future auth; not required for MVP)
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Python VBA microservice (optional, not wired into MVP upload path)
PARSER_SERVICE_URL=http://localhost:8000
